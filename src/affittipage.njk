    <div class="up-section">
    <h1>Prenota la tua vacanza a Scalea</h1>
    </div>
    <div class="center-section">
        <div class="left">
            <div class="bloclf">
                <!-- Верхняя часть -->
                <div class="sopra">
                    <div class="sopra-left">
                        {% if afit.data.images and afit.data.images[0] %}
                            <img alt="Noleggio barche" src="/{{ afit.data.images[0] }}" alt="{{ afit.data.nome }}">
                        {% else %}
                            <img alt="Affitto appartamento" src="/Foto/default.jpg" alt="Default Image">
                        {% endif %}
                    </div>
                    <div class="sopra-right">
                        <div class="right-img">
                            {% if afit.data.images and afit.data.images[1] %}
                                <img alt="Auto per l'aeroporto" src="/{{ afit.data.images[1] }}" alt="{{ afit.data.nome }}">
                            {% else %}
                                <img alt="Affitto bnb in stagione" src="/Foto/default.jpg" alt="Default Image">
                            {% endif %}
                            {% if afit.data.images and afit.data.images[2] %}
                                <img alt="Come arrivare a Scalea" src="/{{ afit.data.images[2] }}" alt="{{ afit.data.nome }}">
                            {% else %}
                                <img alt="Viaggio in yacht" src="/Foto/default.jpg" alt="Default Image">
                            {% endif %}
                        </div>
                        <div class="right-text">
                            <h2>{{ afit.data.h1 }}</h2>
                            <h3>{{ afit.data.h2 }}</h3>
                        </div>
                    </div>
                </div>

                <!-- Нижняя часть -->
                <div class="sotto">
                    <h3>{{ afit.data.h3 }}</h3>
                </div>

                <!-- Кнопка -->
                <div class="affbut">
                <a href="{{ afit.data.link }}" class="glass-link">
                    <button class="glass-button" id="contatButton">Prenota</button>
                </a>    
                </div>
            </div>
        </div>
        <div class="right">
        <!-- Форма обратной связи -->
            <div class="contact-form" id="contactForm">
        <!-- Блок ввода данных -->
        <div class="form-content" id="inputForm">
                <h3>Facci una domanda</h3>
            <label for="phone">Telefono:</label>
            <input type="tel" id="phone" name="phone" required>

            <label for="name">Nome:</label>
            <input type="text" id="name" name="name" required>

            <label for="surname">Cognome:</label>
            <input type="text" id="surname" name="surname" required>
                         
            <label for="city">Mail:</label>
            <input type="mail" id="mail" name="mail" required>         

            <button class="submit-button" id="submitButton" type="button">Inviare</button>
        </div>

                  <!-- Блок благодарности -->
            <div class="thank-you-message" id="thankYouMessage" style="display: none;">
            <h3>Grazie per la tua richiesta!</h3>
            <p>Il nostro responsabile ti contatterà a breve per una consulenza più dettagliata..</p>
            </div>
           </div>            
        </div>
    </div>
