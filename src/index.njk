<section id="about">
    <div class="content-section"> 
        <div class="mapp-container">
            <div id="map" class="map"></div>
        </div>
        <div class="content-bottom">
                    <div class="icons1">
                <a href="https://api.whatsapp.com/send?phone=393791080060&text=Salve%20Da%20Sito" target="_blank" class="whatsapp-icon">
                    <img alt="Contatto diretto con l'agenzia" src="/Foto/Icon/whats.svg" class="icon whatsapp-icon1">
                </a>
                <a href="tel:+393791080060">
                   <img alt="Numero dell'agenzia immobiliare" src="/Foto/Icon/tel.svg" class="icon1">
                </a>
            </div> 
            <!-- Отображаем только 10 блоков на странице -->
{% set count = 0 %}
{% for announcement in collections.announcements %}
    <div class="bottom-block" 
         data-id="{{ announcement.data.riferimento }}" 
         data-riferimento="{{ announcement.data.riferimento }}" 
         data-city="{{ announcement.data.city1 }}" 
         data-zona="{{ announcement.data.nomeZona }}" 
         data-tipo="{{ announcement.data.tipo }}"
         {% if count < 10 %}
             style="display: block;"
         {% else %}
             style="display: none;"
         {% endif %}>
        <!-- Карусель -->
        <div class="carousel-container">
            {% for image in announcement.data.images %}
                <img loading="lazy" alt="Immobiliare in Italia" 
                     src="/{{ image }}" 
                     class="carousel-image {% if loop.index0 == 0 %}active{% endif %}" 
                     alt="Property Image">
            {% endfor %}
            <button class="carousel-btn prev">&#10094;</button>
            <button class="carousel-btn next">&#10095;</button>
        </div>
        <!-- Информация об объекте -->
        <a class="info-block1" href="/anunci/{{ announcement.fileSlug }}/">
            <div class="info-anunci">{{ announcement.data.nomeAnunci }}</div>
        </a>
        <div class="price">
            <a class="euro" href="/anunci/{{ announcement.fileSlug }}/">{{ announcement.data.prezzo }} €</a>
            <a class="rif" href="/anunci/{{ announcement.fileSlug }}/">RIF {{ announcement.data.riferimento }}</a>
        </div>
        <div class="details">
            <span><img alt="Casa" src="/Foto/Icon/mq.svg">{{ announcement.data.zonam2 }}</span>
            <span><img alt="Camere da letto" src="/Foto/Icon/locale.svg">{{ announcement.data.rooms }}</span>
            <span><img alt="Ascensore" src="/Foto/Icon/lift.svg">{{ announcement.data.elevator }}</span>
            <span><img alt="Terrazza" src="/Foto/Icon/terazza.svg">{{ announcement.data.terrazzo }}</span>
            <span><img alt="Bagno" src="/Foto/Icon/bagno.svg">{{ announcement.data.bagni }}</span>
            <span><img alt="Pavimento" src="/Foto/Icon/piano.svg">{{ announcement.data.floor }}</span>
        </div>
        <div class="cta">
            <a href="/anunci/{{ announcement.fileSlug }}/" class="glass-link">
                <button class="glass-button" id="contatButton">Vedi Immobile</button>
            </a>
        </div>
    </div>
    {% set count = count + 1 %}
{% endfor %}

<!-- Кнопка "Показать ещё" -->
<div class="button-anunci" id="loadMoreContainer">
    <button id="loadMoreButton">Mostra altri annunci</button>
</div>
    </div>
        <div class="map-media">
        <div id="mapMedia" class="mapMed"></div>
        </div>
        
    </div>
</section>

    <section id="services">
        <div class="serv-info">
            <div class="serv-text">
                Perchè scegliere la nostra Agenzia
            </div>  
          <div class="serv-block">
        {% set count = 0 %}
        {% for service in collections.services %}
        {% if count < 3 %}    
        <div class="serv-block-1">
            <!-- Изображение -->
            <span class="circle-image">
                <img alt="Servizi di agenzia immobiliare" src="{{ service.data.images[0] | default('/Foto/default.jpg') }}" alt="Service Image">
            </span>

            <!-- Заголовок и описание -->
            <p class="serv-h1">{{ service.data.tipo }}</p>
            <p class="serv-h2">{{ service.data.text }}</p>

            <!-- Кнопка -->
            <div class="cta1">
                <a href="{{ service.data.link | default('#') }}" class="glass-link">
                <button class="glass-button">Scopri di più</button>
                </a>
            </div>
        </div>
                {% set count = count + 1 %}
            {% endif %}
        {% endfor %}
          </div>
        </div>
        
             <div class="recension-blok">
             <div class="dicono"><p>Dicono di noi</p> <hr class="dicono-line" > </div>
                <div class="reviews-block" id="reviews-block">               
                <h2>ECCELLENTE</h2>
                <img alt="La migliore agenzia immobiliare a Scalea" src="/Foto/Icon/star-recen.svg"> <img alt="Recensioni migliori" src="/Foto/Icon/star-recen.svg"> <img alt="Proprietà verificata" src="/Foto/Icon/star-recen.svg"> <img alt="Un'agenzia con una reputazione" src="/Foto/Icon/star-recen.svg"> <img alt="Recensioni oneste" src="/Foto/Icon/star-recen.svg">
                <p>Recensioni : <span id="rating"></span></p>
                <a href="https://www.google.com/maps/place/Italys+Casa/@39.8078084,15.7949074,17.29z/data=!4m8!3m7!1s0x133f1f76f2dbd021:0x3ecbf0ad012a76a4!8m2!3d39.8084272!4d15.7937194!9m1!1b1!16s%2Fg%2F11vwkq4wj_?hl=ru&entry=ttu&g_ep=EgoyMDI1MDMxMi4wIKXMDSoASAFQAw%3D%3D" target="_blank">Visualizza tutte le recensioni su Google Maps</a>
                </div>
             </div>  
    </section>


