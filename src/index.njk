            <div class="static-underline"></div>
        </div>
        <div class="search-bar" style="position: relative;">
            <img alt="All'agenzia immobiliare" src="/Foto/Icon/Home.svg" alt="Home Icon" class="icon">
            <input type="text" id="searchInput" placeholder="Provincia, Comune, Zona, Riferimento">
            <button id="clearSearch" class="search-clear">×</button>
            <img alt="Ricerca immobili" src="/Foto/Icon/Search.svg" alt="Search Icon" class="icon">
        </div>
    </div>
