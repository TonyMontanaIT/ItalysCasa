        <link rel="stylesheet" type="text/css" href="/styles/anunci.css">
        <link rel="icon" src="/Foto/Icon/favicon.svg" type="image/x-icon">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/css/intlTelInput.min.css">
        <script>
            window.CurrentAnnouncement = {
                lat: {{ announcement.data.latitude }},
                lon: {{ announcement.data.longitude }},
                nomeAnunci: "{{ announcement.data.nomeAnunci }}",
                prezzo: "{{ announcement.data.prezzo }}",
                rif: "{{ announcement.data.riferimento }}",
                fileSlug: "{{ announcement.fileSlug }}"
            };
        </script>
        <script>
            window.Announcements = {{ collections.mapData | json | safe }};
        </script>
        <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js"></script>
