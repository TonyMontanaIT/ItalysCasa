                <p><strong>Città:</strong> {{ announcement.data.city1 }}</p> 
                <p><strong>Via:</strong> {{ announcement.data.street1 }}</p>
            </div>
        </div>
        <div class="up-icon">
            <div class="up-icon-left">
                <div class="street-rif">
                    <h3>RIF:{{ announcement.data.riferimento }}</h3>
                </div>
                <div class="street-viale1">
                    <h1>€{{ announcement.data.prezzo }}</h1>
                </div>                         
            </div>
            <div class="up-icon-right">
                <a href="/property">Lista Annunci</a>
