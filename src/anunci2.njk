                <!-- Стрелки -->
                <button class="carousel-btn prev">&#10094;</button>
                <button class="carousel-btn next">&#10095;</button>
            </div>
        </div>

<!-- Модальное окно для просмотра изображений -->
<div class="modal" id="imageModal" style="display: none;">
