---
layout: layout.njk
pagination:
    data: collections.announcements
    size: 1
    alias: announcement
    filter: "{{ announcement.fileSlug }}"
permalink: "/anunci/{{ announcement.fileSlug }}/index.html"
---

        <link rel="stylesheet" type="text/css" href="/styles/anunci.css">
        <link rel="icon" src="/Foto/Icon/favicon.svg" type="image/x-icon">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/css/intlTelInput.min.css">
        <script>
            window.Announcements = {{ collections.announcements | safe }};
        </script>
        <script>
            window.Announcements = {{ collections.mapData | json | safe }};
        </script>
        <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js"></script>

<div class="content-section">
    <div class="up-section">
        <div class="up-left">
            <div class="up-left-up">
                <div class="street-rif">
                    <h1>{{ announcement.data.nomeAnunci }}</h1>
                </div>
                <div class="street-viale">
                    <h1>{{ announcement.data.nomeZona }}</h1>
                </div>                      
            </div>
            <div class="up-left-down">
                <p><strong>Città:</strong> {{ announcement.data.city1 }}</p> 
                <p><strong>Via:</strong> {{ announcement.data.street1 }}</p>
            </div>
        </div>
        <div class="up-icon">
            <div class="up-icon-left">
                <div class="street-rif">
                    <h3>RIF:{{ announcement.data.riferimento }}</h3>
                </div>
                <div class="street-viale1">
                    <h1>€{{ announcement.data.prezzo }}</h1>
                </div>                         
            </div>
            <div class="up-icon-right">
                <a href="/vendite">Lista Annunci</a>
                <a href="#" class="share-link"> <img src="/Foto/Icon/share.svg"> </a>
            </div>
        </div>
    </div>

    <div class="center-section">
        <div class="center-left">
            <!-- Карусель -->
            <div class="carousel-container">
                {% for image in announcement.data.images %}
                    <img src="/{{ image }}" class="carousel-image {% if loop.index0 == 0 %}active{% endif %}" alt="Property Image">
                {% endfor %}
                <!-- Иконки -->
                <div class="icon-container">
                    <a href="#" class="open-modal" data-index="0"><img src="/Foto/Icon/cameraFoto.svg" alt="Foto" class="anunci-icon"></a>
                    <a href="{{ announcement.data.video }}"><img src="/Foto/Icon/cameraVideo.svg" alt="Video" class="anunci-icon"></a>
                    <a href="{{ announcement.data.video360 }}"><img src="/Foto/Icon/camera360.svg" alt="360" class="anunci-icon"></a>
                    <a href="#"><img src="/Foto/Icon/geomappa.svg" alt="Mappa" class="anunci-icon"></a>
                </div>
                <!-- Стрелки -->
                <button class="carousel-btn prev">&#10094;</button>
                <button class="carousel-btn next">&#10095;</button>
            </div>
        </div>

<!-- Модальное окно для просмотра изображений -->
<div class="modal" id="imageModal" style="display: none;">
    <div class="modal-content">
        <span class="close-modal" id="closeModal">&times;</span>
        <button class="modal-btn prev" id="modalPrev">&#10094;</button>
        <img src="" id="modalImage" alt="Full Image">
        <button class="modal-btn next" id="modalNext">&#10095;</button>
    </div>
    <div class="modal-thumbnails">
        <!-- Превью для модального окна -->
        {% for image in announcement.data.images %}
            <img src="/{{ image }}" class="modal-thumbnail {% if loop.index0 == 0 %}active{% endif %}" alt="Thumbnail" data-index="{{ loop.index0 }}">
        {% endfor %}
    </div>
</div>


        <div class="center-center">
                    <div class="cen-info">
                        <div class="caratter">
                            <img src="/Foto/Icon/caracter.svg">
                         <p>Caratteristiche:</p>
                        </div>
                <div class="property-info">
                    <div class="info-item">
                     <p><strong>RIF:</strong> {{ announcement.data.RIF1 }}</p> 
                     <p><strong>Tipo:</strong> {{ announcement.data.tipo }}</p> 
                     <p><strong>Camere da letto:</strong> {{ announcement.data.rooms }}</p> 
                     <p><strong>Locali:</strong> {{ announcement.data.totalrooms }}</p> 
                     <p><strong>Bagni:</strong> {{ announcement.data.bagni }}</p> 
                     <p><strong>Mq commerciali:</strong> {{ announcement.data.zonam2 }}</p> 
                     <p><strong>Piano:</strong> {{ announcement.data.floor }}</p> 
                     <p><strong>Ascensore:</strong> {{ announcement.data.elevator }}</p> 
                     <p><strong>Terrazzo:</strong> {{ announcement.data.terrazzo }}</p> 
                     <p><strong>Giardino:</strong> {{ announcement.data.giardino }}</p> 
                     <p><strong>Box Auto:</strong> {{ announcement.data.garage }}</p> 
                     <p><strong>Prezzo: €:</strong> {{ announcement.data.prezzo }}</p> 
                    </div>
                    <div class="info-window">
                        <a href="#" id="openModalButton" class="glass-link">
                        <bottom class="glass-button1">Vedi tutte</bottom></a>
                    </div>                   
                </div>
                    </div>
        </div>
        <div class="center-right">
            <div class="mapp-container">
                <div id="map-small" class="map"></div>
            </div>
        </div>
    </div>
            <div class="dawn">
              <div class="content-block">
            <div class="descrizione">
                <div class="des-info">
                    <div class="des-info-start">
                <img src="/Foto/Icon/description.svg">
                <h1>{{ announcement.data.descrizione }}</h1>
                    </div>
                     <div class="des-info-text">
                       <p class="pclassH2">{{ announcement.data.h2t1 }}</p>
                       <p class="pclassText">{{ announcement.data.text1 }}</p>
                       <p class="pclassH2">{{ announcement.data.h2t2 }}</p>
                       <p class="pclassText">{{ announcement.data.text2 }}</p>
                       <p class="pclassH2">{{ announcement.data.h2t3 }}</p>
                       <p class="pclassText">{{ announcement.data.text3 }}</p>
                       <p class="pclassH2">{{ announcement.data.h2t4 }}</p>
                       <p class="pclassText">{{ announcement.data.text4 }}</p>
                       <p class="pclassH2">{{ announcement.data.h2t5 }}</p>
                       <p class="pclassText">{{ announcement.data.text5 }}</p>
                       <p class="pclassH2">{{ announcement.data.h2t6 }}</p>
                       <p class="pclassText">{{ announcement.data.text6 }}</p>
                       <p class="pclassH2">Prezzo richiesto: €{{ announcement.data.prezzo }}</p>
                       <p class="pclassText1"><span class="pclassH2">Contattaci</span> al numero <a href="tel:+393791080060" class="telYelow">393791080060</a> o visita il nostro sito web <a href="#" class="telYelow">italyscasa.com</a></p>
                       <p class="pclassText1">Visita le nostre pagine:</p>
                       <p class="pclassText1">Instagram:<a href="https://www.instagram.com/italyscasa/" class="telYelow">italyscasa,</a> Facebook:<a href="https://www.facebook.com/profile.php?id=61551668563870" class="telYelow">Italys casa,</a>YouTube:<a href="https://www.youtube.com/@ItalysCasa" class="telYelow">italyscasa</a> e TikTok:<a href="https://www.tiktok.com/@italyscasa1" class="telYelow">italyscasa1.</a></p>
                     </div>                     
                </div>
         </div>   
         <div class="map-big">
             <div id="map-big" class="map"></div>
         </div>         
            <div class="button-video">
                    <!-- Кнопка для обычного видео -->
                {% if announcement.data.video %}
                <a href="{{ announcement.data.video }}" target="_blank" class="video-button">
                <button><span class="VideoSu">Video su</span> <span class="you">You</span><span class="tube">Tube</span></button>
                </a>
                {% endif %}

                    <!-- Кнопка для видео 360 -->
                {% if announcement.data.video360 %}
                <a href="{{ announcement.data.video360 }}" target="_blank" class="video360-button">
                <button><span class="virtual">Virtual Tour </span><span class="gradus">360°</span></button>
                </a>
                {% endif %}

                <a href="tel:+393791080060" class="abuttel"><img src="/Foto/Icon/tel.svg" alt="Phone Icon" class="iconphone">
                Chiamata
                </a>
                <a href="https://api.whatsapp.com/send?phone=393791080060&text=Salve%20Da%20Sito" target="_blank" class="awhats">
                WhatsApp
                </a>
            </div>

   <section id="random">
    <div class="serv-info">
        <div class="serv-text">
            Proposte selezionate per te!
        </div>  
        <div class="serv-block">
            {% set count = 0 %}
            {% for Random in collections.random %}
                {% if count < 3 %}
                    <div class="serv-block-1">
                        <!-- Изображение -->
                        <span class="circle-image">
                            <img src="/{{ Random.data.images[0] | default('/Foto/default.jpg') }}" alt="Service Image">
                        </span>
                        <div class="random-info">
                        <!-- Заголовок и описание -->
                        <div class="random-nome">
                        <p class="serv-h1">{{ Random.data.nomeAnunci }}</p>
                        </div>
                        <div class="random-prezzo">
                            <a href="/anunci/{{ Random.fileSlug }}/">€ {{ Random.data.prezzo }}</a>
                            <span>RIF:{{ Random.data.RIF1 }}</span>
                        </div>
                        <div class="random-icon">
                        <span><img src="/Foto/Icon/bagno.svg" alt=""> {{ Random.data.bagni }}</span>
                        <span><img src="/Foto/Icon/mq.svg"> {{ Random.data.zonam2 }}</span>
                        <span><img src="/Foto/Icon/locale.svg"> {{ Random.data.rooms }}</span>
                        <span><img src="/Foto/Icon/terazza.svg"> {{ Random.data.terrazzo }}</span>
                        </div>
                        </div>
                        <!-- Кнопка -->
                        <div class="cta1">
                            <a href="/anunci/{{ Random.fileSlug }}/">
                            <button class="glass-button">Scopri di più</button>
                            </a>
                        </div>
                    </div>
                    {% set count = count + 1 %}
                {% endif %}
            {% endfor %}
        </div>
    </div>  
</section>
          </div>

<!-- Модальное окно -->
<div class="modal-overlay" id="modalOverlay">
    <div class="modal-content1">
        <button class="close-button" id="closeModalButton">X</button>
        <div class="info-items">
            <div class="info-item1">
                <p><strong>RIF:</strong> {{ announcement.data.RIF1 }}</p>
                <p><strong>Tipo:</strong> {{ announcement.data.tipo }}</p>
                <p><strong>Camere da letto:</strong> {{ announcement.data.rooms }}</p> 
                <p><strong>Locali:</strong> {{ announcement.data.totalrooms }}</p>
                <p><strong>Bagni:</strong> {{ announcement.data.bagni }}</p>
                <p><strong>Mq commerciali:</strong> {{ announcement.data.zonam2 }}</p>
                <p><strong>Piano:</strong> {{ announcement.data.floor }}</p>
                <p><strong>Ascensore:</strong> {{ announcement.data.elevator }}</p>
                <p><strong>Terrazzo:</strong> {{ announcement.data.terrazzo }}</p>
                <p><strong>Prezzo: €:</strong> {{ announcement.data.prezzo }}</p>
            </div>
            <div class="info-item1">
                <p><strong>Città:</strong> {{ announcement.data.city1 }}</p>
                <p><strong>Nome:</strong> {{ announcement.data.nomeAnunci }}</p>
                <p><strong>Zona:</strong> {{ announcement.data.nomeZona }}</p>
                <p><strong>Via:</strong> {{ announcement.data.street1 }}</p>
            </div>            
            <!-- Добавь еще блоки, если нужно, каждый с классом info-item -->
        </div>
    </div>
</div>

          <!-- Форма обратной связи -->
            <div class="contact-form" id="contactForm">
                         <!-- Блок ввода данных -->
            <div class="form-content" id="inputForm">
                <h3>Facci una domanda</h3>
            <label for="name">Nome:</label>
            <input type="text" id="name" name="name" required>

            <label for="surname">Cognome:</label>
            <input type="text" id="surname" name="surname" required>

            <label for="phone">Telefono:</label>
            <input type="tel" id="phone" name="phone" required>
             
            <label for="text">Testo</label>
            <textarea id="text" name="text" required></textarea>
            

            <button class="submit-button" id="submitButton" type="button">Inviare</button>
        </div>

                  <!-- Блок благодарности -->
            <div class="thank-you-message" id="thankYouMessage" style="display: none;">
                <h3>Grazie per la tua richiesta!</h3>
                <p>Il nostro responsabile ti contatterà a breve per una consulenza più dettagliata..</p>
            </div>
           </div>
         </div>

</div>
<script src="https://cdnjs.cloudflare.com/ajax/libs/intl-tel-input/17.0.8/js/intlTelInput.min.js"></script>
<script src="/script/anunci.js"></script> 
