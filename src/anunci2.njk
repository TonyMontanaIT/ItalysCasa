        </div>
    </div>

    <div class="center-section">
        <div class="center-left">
            <!-- Карусель -->
            <div class="carousel-container">
                {% for image in announcement.data.images %}
                    <img alt="I migliori appartamenti in Italia" src="/{{ image }}" class="carousel-image {% if loop.index0 == 0 %}active{% endif %}" alt="Property Image">
                {% endfor %}
                <!-- Иконки -->
                <div class="icon-container">
                    <a href="#" class="open-modal" data-index="0"><img src="/Foto/Icon/cameraFoto.svg" alt="Foto" class="anunci-icon"></a>
                    <a href="{{ announcement.data.video }}"><img src="/Foto/Icon/cameraVideo.svg" alt="Video" class="anunci-icon"></a>
                    <a href="{{ announcement.data.video360 }}"><img src="/Foto/Icon/camera360.svg" alt="360" class="anunci-icon"></a>
                    <a href="#" id="scrollToMapButton">
                    <img src="/Foto/Icon/geomappa.svg" alt="Mappa" class="anunci-icon">
                    </a>
