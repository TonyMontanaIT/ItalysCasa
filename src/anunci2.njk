        <button class="modal-btn next" id="modalNext">&#10095;</button>
    </div>
    <div class="modal-thumbnails">
        <!-- Превью для модального окна -->
        {% for image in announcement.data.images %}
            <img alt="Appartamento con una bellissima vista" src="/{{ image }}" class="modal-thumbnail {% if loop.index0 == 0 %}active{% endif %}" alt="Thumbnail" data-index="{{ loop.index0 }}">
        {% endfor %}
    </div>
</div>


